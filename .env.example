# ============================================================================
# 🎵 BeatMarket — Variables d'environnement
# ============================================================================
# Copiez ce fichier vers .env.local et remplissez les valeurs
# cp .env.example .env.local
# ============================================================================

# ---- Base de données (Supabase PostgreSQL) ----
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-genere-avec-openssl-rand-base64-32"

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- PayPal (optionnel) ----
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# ---- AWS S3 / Cloudflare R2 ----
S3_BUCKET_NAME="beatmarket-audio"
S3_REGION="eu-west-3"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="" # Pour R2: https://[ACCOUNT_ID].r2.cloudflarestorage.com

# ---- Redis (Upstash) ----
REDIS_URL="redis://default:...@eu1-...upstash.io:6379"

# ---- Resend (Emails transactionnels) ----
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@beatmarket.com"

# ---- Application ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BeatMarket"
PLATFORM_COMMISSION_RATE="0.15"
